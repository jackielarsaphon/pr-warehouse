# คัดลอกไฟล์นี้เป็น `.env` แล้วเติมค่าจริง — `.env` อยู่ใน .gitignore ห้าม commit
# (ค่า secret ด้านล่างใส่เป็น placeholder ไว้ ให้แทนด้วยของจริงในเครื่อง)

# ------------------------------------------
# Supabase (ระบบ MWM / Employee project)
# ------------------------------------------
VITE_SUPABASE_URL_MWM=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY_MWM=<anon_key>
VITE_SUPABASE_BUCKET_MWM=document_url
VITE_SUPABASE_EMPLOYEE_PROJECT2_DB=https://<project>.supabase.co
VITE_SUPABASE_DB_ANON_KEY_EMPLOYEE_PROJECT2=<anon_key>

# ------------------------------------------
# TRCLOUD API Direct Config
# ------------------------------------------
VITE_TRCLOUD_COMPANY_ID=25
VITE_TRCLOUD_PASSKEY=<passkey>
VITE_TRCLOUD_BASE_URL=https://thaidrill.trcloud.co/application

# ------------------------------------------
# TRCLOUD AUTO-LOGIN (เฉพาะ dev server / proxy — ไม่ใส่ prefix VITE_)
# กลไก + วิธีแก้ปัญหา: ดู docs/TRCLOUD_AUTH.md
# ------------------------------------------
# true = ให้ dev server ล็อกอิน TRCloud เองทุกครั้งที่ start (ไม่ต้อง copy cookie เอง)
TRCLOUD_USE_LOGIN_COOKIE=true
TRCLOUD_USERNAME=<username>
TRCLOUD_PASSWORD=<password>
# device id = ค่า cookie `trcloud` ของเครื่องที่ TRCloud "อนุมัติแล้ว"
# ถ้าไม่ตั้งค่านี้ ระบบจะ parse ค่า trcloud= จาก TRCLOUD_COOKIE ให้แทน
TRCLOUD_DEVICE_ID=<trcloud_cookie_value>

# cookie สำรอง (ใช้เมื่อปิด auto-login หรือ auto-login ล้มเหลว)
# รูปแบบ: คัดลอก Cookie ทั้งบรรทัดจากเบราว์เซอร์หลังล็อกอิน (ต้องมี PHPSESSID + trcloud)
TRCLOUD_COOKIE=trcloud=<trcloud_cookie_value>

# ------------------------------------------
# โหมดจำลอง DB ในเครื่อง (true = ไม่ยุ่ง Supabase จริง, เก็บใน localStorage)
# ------------------------------------------
VITE_USE_MOCK_DB=true

# ------------------------------------------
# ตั้งค่าทั่วไป
# ------------------------------------------
VITE_DATE_FROM=2026-02-01
VITE_DATE_TO=2026-05-30
VITE_REFRESH_SEC=30
